{
  "name": "finds-you-jobs",
  "version": "0.5.3",
  "private": true,
  "description": "Open-source AI job-search desktop tool",
  "license": "AGPL-3.0-only",
  "scripts": {
    "boot": "cd frontend && pnpm install && cd .. && pnpm install && uv sync",
    "dev": "node scripts/dev.mjs",
    "dev:web": "node scripts/dev.mjs web",
    "tauri": "tauri",
    "build": "node scripts/codegen.mjs && cd frontend && pnpm build && cd .. && pnpm tauri build",
    "test": "node scripts/codegen.mjs && uv run pytest",
    "lint": "uv run ruff check .",
    "typecheck": "uv run pyright sidecar && cd frontend && pnpm typecheck",
    "playwright": "cd frontend && pnpm playwright test",
    "codegen": "node scripts/codegen.mjs"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.9.0",
    "openapi-typescript": "^7.4.0"
  },
  "packageManager": "pnpm@9.0.0"
}
